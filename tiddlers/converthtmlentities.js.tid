title: converthtmlentities.js
type: application/javascript

  function convertHTML(str) {
    // &colon;&rpar;
    str = str.split('').map(swapper).join('');
    return str;

    function swapper(val) {
      switch (val) {
        case "&": {return "&amp;"};
        case "<": {return "&lt;"};
        case ">": {return "&gt;"};
        case "\'": {return "&apos;"};
        case "\"": {return "&quot;"};
      }
      return val;
    }
  }


  console.log(  convertHTML("Dolce & < > ' \" Gabbana"));
