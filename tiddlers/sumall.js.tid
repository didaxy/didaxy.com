  function sumAll(arr) {
    var sum = 0;
    arr = arr.sort(function(a,b){return a - b;});
    for (var i=arr[0]; i<=arr[1];i++) {
      sum += i;
    }
    return sum;
  }
  console.log("out: " + sumAll([2,4]));