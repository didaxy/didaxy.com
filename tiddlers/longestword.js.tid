  function findLongestWord(str) {
    return str.split(' ').map(function(word) {return word.length;}).reduce(function (prev, curr){return Math.max(prev, curr);},0);
  }


  console.log("ans:" + findLongestWord("The quick brown fox jumped over the lazy dog"));
