  function uniteUnique() {
    var argsAsArray = Array.prototype.slice.call(arguments);
    var wholeArray = [].concat.apply([], argsAsArray);
    var reducedArray = wholeArray.reduce(function(acc,curr) {
      if (acc.indexOf(curr) < 0) {acc.push(curr)}
      return acc;
    },[])
    return reducedArray;
   }

  console.log(uniteUnique([1, 3, 2], [5, 2, [2], 4], [2, 1]));
