function addTogether(a,b) {
    if (a && typeof(a) === "number") {
      if (b) {
        if (typeof(b) === "number") {
          return a + b;
        }
        else {
          return undefined;
        }
      }
      else {
        return function(b){
          if (b && typeof(b) === "number") {
            return a + b;
          }
          else {
            return undefined;
          }
        }
      }
    }
  }

  console.log(addTogether(2)(2));