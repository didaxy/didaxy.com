title: steamroller.js
type: application/javascript

  function steamrollArray(arr) {
    // I'm a steamroller, baby
    var result;
    result = arr.reduce(function(acc,val){
      if (Array.isArray(val)) {return acc.concat(steamrollArray(val))}
      return acc.concat([val])
    },[]);
    return result;
  }

  console.log(steamrollArray([1, [2], [3, [[4]],6]]));