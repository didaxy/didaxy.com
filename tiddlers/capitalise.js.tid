  function titleCase(str) {
    arr = str.split(' ');
    console.log(arr);
    for (var i=0; i < arr.length; i++) {
      arr[i] = arr[i].charAt(0).toUpperCase() + arr[i].slice(1).toLowerCase();
    }
    str = arr.join(' ');

    return str;
  }


  console.log(titleCase("I'm a litTle tea pot"));