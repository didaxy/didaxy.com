  function truthCheck(collection, pre) {

    return collection.reduce(function(acc,val) {
      return acc && val.hasOwnProperty(pre) && !!val[pre] ;
    }, true);
  }

  console.log(truthCheck([{"user": "Tinky-Winky", "sex": "male"}, {"user": "Dipsy", "sex": "male"}, {"user": "Laa-Laa", "sex":"."}, {"user": "Po", "sex": undefined}], "sex"));
